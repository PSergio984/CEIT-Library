        @forelse ($this->notifications as $notification)
            <div wire:key="notification-{{ $notification->id }}"
                class="card bg-base-100 border border-base-300 shadow-sm hover:shadow-md transition-shadow {{ !$notification->is_read ? 'border-l-4 border-l-primary' : '' }}">
                <div class="card-body p-4">
                    <div class="flex items-start justify-between gap-4">
                        <div class="flex-1">
                            <div class="flex items-start gap-2 mb-2">
                                @if($notification->type === 'system')
                                    <x-mary-icon name="o-cog" class="w-5 h-5 text-info shrink-0 mt-0.5" />
                                @elseif($notification->type === 'user_activity')
                                    <x-mary-icon name="o-user-group" class="w-5 h-5 text-success shrink-0 mt-0.5" />
                                @elseif($notification->type === 'violation')
                                    <x-mary-icon name="o-exclamation-triangle" class="w-5 h-5 text-error shrink-0 mt-0.5" />
                                @elseif($notification->type === 'role_changed')
                                    <x-mary-icon name="o-user-circle" class="w-5 h-5 text-warning shrink-0 mt-0.5" />
                                @else
                                    <x-mary-icon name="o-bell" class="w-5 h-5 text-warning shrink-0 mt-0.5" />
                                @endif

                                <div class="flex-1">
                                    <h3 class="font-semibold text-base {{ !$notification->is_read ? 'text-primary' : '' }}">
                                        {{ $notification->title }}
                                    </h3>
                                    <p class="text-sm text-base-content/70 mt-1">
                                        {{ $notification->message }}
                                    </p>
                                </div>
                            </div>

                            <div class="flex flex-wrap items-center gap-3 mt-3 text-xs text-base-content/60">
                                <div class="flex items-center gap-1">
                                    <x-mary-icon name="o-clock" class="w-3.5 h-3.5" />
                                    <span>{{ $notification->created_at->diffForHumans() }}</span>
                                </div>

                                @if($notification->is_read)
                                    <div class="badge badge-success badge-sm">
                                        <x-mary-icon name="o-check" class="w-3 h-3 mr-1" />
                                        Read
                                    </div>
                                @else
